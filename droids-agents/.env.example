# droids-agents environment
# Copy to .env and fill in real values:  cp .env.example .env
# Resolution order (later wins): ~/.droids-agents/.env  then  ./.env

# ============================================
# Required
# ============================================
# Anthropic API key for classifier + specialists.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bearer token for the droids-mem MCP bridge.
# If unset, config falls back to ~/.droids-mem/token (run `droids-mem ensure-server` first).
DROIDS_MEM_MCP_TOKEN=your_droids_mem_token_here

# ============================================
# Service endpoints (defaults shown — override only for non-local)
# ============================================
DROIDS_MEM_MCP_URL=http://localhost:7777/mcp
AGENTSPAN_URL=http://localhost:6767

# ============================================
# Gmail (OPTIONAL — set BOTH to enable the messaging Subteam)
# Generate via: uv run droids-agents auth gmail
# ============================================
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# ============================================
# Optional tuning
# ============================================
# Log output dir (default: ~/.droids-agents/logs/)
DROIDS_AGENTS_LOG_DIR=
# Comma-separated recipient domains that skip HITL. Empty → every recipient pauses.
DROIDS_AGENTS_EMAIL_ALLOWLIST=
# Override for droid-infra/droids-name.yml
DROIDS_NAMES_FILE=
